[ {
  "indice" : 7,
  "estilo" : "Karaoke Simples",
  "original" : "...puxe-os para perto de mim.",
  "traduzido" : "Puxe-os para perto de mim.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 258,
  "estilo" : "Karaoke Simples",
  "original" : "I was watching you as you were watching the sun rise.",
  "traduzido" : "Eu estava observando você enquanto você observava o sol nascer.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 259,
  "estilo" : "Karaoke Simples",
  "original" : "Two of us",
  "traduzido" : "Dois de nós",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 260,
  "estilo" : "Karaoke Simples",
  "original" : "When we counted the things we didn't have enough of...",
  "traduzido" : "Ao contarmos as coisas que não tínhamos o suficiente...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 261,
  "estilo" : "Karaoke Simples",
  "original" : "...it all just suddenly seemed so funny...",
  "traduzido" : "Pareceu tudo tão engraçado de repente...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 262,
  "estilo" : "Karaoke Simples",
  "original" : "...and our voices grew louder as we laughed.",
  "traduzido" : "E nossas vozes ficaram mais altas enquanto rimos.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 263,
  "estilo" : "Karaoke Simples",
  "original" : "Our only answer to the torment we felt as the days passed...",
  "traduzido" : "A única resposta para o tormento que sentimos à medida que os dias passavam...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 264,
  "estilo" : "Karaoke Simples",
  "original" : "...was for the both of us to walk on.",
  "traduzido" : "Para que ambos pudéssemos caminhar juntos.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 265,
  "estilo" : "Karaoke Simples",
  "original" : "And the loneliness we share...",
  "traduzido" : "E a solidão que compartilhamos...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 266,
  "estilo" : "Karaoke Simples",
  "original" : "...taught us what warmth really is.",
  "traduzido" : "Ensinou-nos o que é realmente calor.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 268,
  "estilo" : "Karaoke Simples",
  "original" : "If we embrace each other...",
  "traduzido" : "Se nos abraçarmos...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 270,
  "estilo" : "Karaoke Simples",
  "original" : "...even tears don't matter.",
  "traduzido" : "...nem lágrimas importam.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 272,
  "estilo" : "Karaoke Simples",
  "original" : "My dearest love...",
  "traduzido" : "Minha amada...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 275,
  "estilo" : "Karaoke Simples",
  "original" : "So the two of us in the future...",
  "traduzido" : "No futuro, apenas nós dois...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 276,
  "estilo" : "Karaoke Simples",
  "original" : "...won't laugh at us here now...",
  "traduzido" : "Ninguém vai rir de nós agora...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 279,
  "estilo" : "Karaoke Simples",
  "original" : "Now, let's have a pleasant dream.",
  "traduzido" : "Agora, vamos ter um sonho agradável.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
} ]