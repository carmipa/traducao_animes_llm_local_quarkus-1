    "original" : "{\\blur2.5\\c&H171417&\\fscx200\\fscy200\\t(,(22,231,\\fscx100\\fscy100\\blur1)\\clip(m -1.375 0 l -1.375 1080 1440 1080)\\move(166,901,511,691,22,231)}MS TEAM",
    "traduzido" : "{\\blur2.5\\c&H171417&\\fscx200\\fscy200\\t(,(22,231,\\fscx100\\fscy100\\blur1)\\clip(m -1.375 0 l -1.375 1080 1440 1080)\\move(166,901,511,691,22,231)}EQUIPE MS",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 2,
    "estilo" : "Dialogue",
    "original" : "It's true! A star fell down and then\\Nthere was a light in the desert.",
    "traduzido" : "Uma estrela caiu mesmo! E então\\Napareceu uma luz no deserto.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 3,
    "estilo" : "Dialogue",
    "original" : "Right. And where did you see this light?",
    "traduzido" : "E então, onde você viu essa luz?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 4,
    "estilo" : "Dialogue",
    "original" : "The desert to the west.",
    "traduzido" : "Deserto a oeste.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 5,
    "estilo" : "Dialogue",
    "original" : "I saw the same flash about 3 days ago, too.",
    "traduzido" : "Vi o mesmo clarão há cerca de três dias também.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 6,
    "estilo" : "Dialogue",
    "original" : "Thanks.",
    "traduzido" : "De nada.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 7,
    "estilo" : "Dialogue",
    "original" : "Shiro, that intel was right!",
    "traduzido" : "Shiro, tinha razão sobre aquela inteligência!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 8,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Contact headquarters\\Nand every team in the area.{\\i}",
    "traduzido" : "{\\i1}Entre em contato com o quartel-general\\Ne todas as equipes da área.{\\i}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 9,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Hey! Did you hear me?",
    "traduzido" : "{\\i1}Ei! Você ouviu o que eu disse?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 10,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Michel!",
    "traduzido" : "{\\i1}Michel!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 11,
    "estilo" : "Dialogue",
    "original" : "Yes, sir! What is it?",
    "traduzido" : "Sim, senhor! O que é?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 12,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Contact headquarters!{\\i}",
    "traduzido" : "{\\i1}Contate o quartel-general!{\\i}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 13,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Yes, sir. Go ahead.",
    "traduzido" : "{\\i1}Sim, senhor. Pode continuar.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 14,
    "estilo" : "Dialogue",
    "original" : "{\\i1}The 08th has discovered evidence...",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 15,
    "estilo" : "Dialogue",
    "original" : "{\\i1}...of the location of the Zeon\\Nweapons testing ground.",
    "traduzido" : "{\\i1}...localizacao do campo\\Nde testes de armas da Zeon.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 16,
    "estilo" : "Dialogue",
    "original" : "{\\i1}We're moving in to confirm.",
    "traduzido" : "{\\i1}Estamos avançando para confirmar.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 17,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Roger.",
    "traduzido" : "{\\i1}Entendido.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 18,
    "estilo" : "Dialogue",
    "original" : "There it goes again... This is Shiro.",
    "traduzido" : "Lá vai outra vez... Aqui é o Shiro.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 19,
    "estilo" : "Dialogue",
    "original" : "{\\i1}My left foot's acting up again.\\NGo on ahead of me.",
    "traduzido" : "{\\i1}Meu pé esquerdo está me\\Nincomodando outra vez. Vá na frente.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 20,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Will you be okay by yourself?",
    "traduzido" : "{\\i1}Você vai ficar bem sozinha?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 21,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Michel and I will manage somehow.",
    "traduzido" : "{\\i1}Michel e eu vamos dar um jeito.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 22,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Roger.",
    "traduzido" : "{\\i1}Entendido.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 23,
    "estilo" : "Dialogue",
    "original" : "{\\i1}I don't read any radiation.",
    "traduzido" : "{\\i1}Não detecto nenhum sinal de radiação.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 24,
    "estilo" : "Dialogue",
    "original" : "Roger.",
    "traduzido" : "Entendido.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 25,
    "estilo" : "Dialogue",
    "original" : "One, two... Pull!",
    "traduzido" : "Um, dois... Puxe!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 26,
    "estilo" : "Dialogue",
    "original" : "One, two... Pull!",
    "traduzido" : "Um, dois... Puxe!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 27,
    "estilo" : "Dialogue",
    "original" : "One, two... Pull!",
    "traduzido" : "Um, dois... Puxe!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 28,
    "estilo" : "Dialogue",
    "original" : "How's it look?",
    "traduzido" : "Como está parecendo?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 29,
    "estilo" : "Dialogue",
    "original" : "Right, right. I'm getting to it.",
    "traduzido" : "Entendi, entendi. Estou indo.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 30,
    "estilo" : "Dialogue",
    "original" : "Glass? A beam weapon\\Nmelted this to glass.",
    "traduzido" : "Vidro? Uma arma de feixe\\Nderreteu isso até virar vidro.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 31,
    "estilo" : "Dialogue",
    "original" : "Commander! The pack-in's screwed up...",
    "traduzido" : "Comandante! A embalagem está uma bagunça...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 32,
    "estilo" : "Dialogue",
    "original" : "...and the filter's clogged with sand!",
    "traduzido" : "E o filtro está entupido de areia!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 33,
    "estilo" : "Dialogue",
    "original" : "Could I have an M-18 filter, please?",
    "traduzido" : "Podería ter um filtro M-18, por favor?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 34,
    "estilo" : "Dialogue",
    "original" : "Hold on a second!",
    "traduzido" : "Aguarde um segundo!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 35,
    "estilo" : "Dialogue",
    "original" : "{\\i1}The angle of fire indicates\\Nit came from low altitude.",
    "traduzido" : "{\\i1}O ângulo de tiro indica\\Nque veio de baixa altitude.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 36,
    "estilo" : "Dialogue",
    "original" : "This has to be the testing ground.",
    "traduzido" : "Este deve ser o campo de testes.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 37,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Yes, sir.",
    "traduzido" : "{\\i1}Sim, senhor.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
