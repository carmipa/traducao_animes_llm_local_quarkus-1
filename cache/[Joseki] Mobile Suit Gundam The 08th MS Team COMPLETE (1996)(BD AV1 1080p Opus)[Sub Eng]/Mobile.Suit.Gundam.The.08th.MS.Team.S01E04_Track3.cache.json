  "entradas" : [ {
    "indice" : 1,
    "estilo" : "08thMS",
    "original" : "{\\blur2.5\\c&H171417&\\fscx200\\fscy200\\t(,(22,231,\\fscx100\\fscy100\\blur1)\\clip(m -1.375 0 l -1.375 1080 1440 1080)\\move(166,901,511,691,22,231)}MS TEAM",
    "traduzido" : "{\\blur2.5\\c&H171417&\\fscx200\\fscy200\\t(,(22,231,\\fscx100\\fscy100\\blur1)\\clip(m -1.375 0 l -1.375 1080 1440 1080)\\move(166,901,511,691,22,231)}EQUIPE MS",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 2,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Currently holding at\\Nan altitude of 9500!",
    "traduzido" : "{\\i1}Atualmente mantendo\\Naltitude de 9500 metros!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 3,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Wind speed: 0.5 to 0.6.",
    "traduzido" : "{\\i1}Vento soprando a 0.5 a 0.6.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 4,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Area is clear of enemy presence.",
    "traduzido" : "{\\i1}Área livre de presença inimiga.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 5,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Escort plane, stay on guard!",
    "traduzido" : "{\\i1}Plano de escolta, fiquem alertas!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 6,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Yes, sir!",
    "traduzido" : "{\\i1}Sim, senhor!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 7,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Flight program, check!",
    "traduzido" : "{\\i1}Programa de voo, checado!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 8,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Linking main computer.",
    "traduzido" : "{\\i1}Conectando computador principal.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 9,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Gyro system, activated.\\NTrim control, on.",
    "traduzido" : "{\\i1}Sistema giroscópico ativado.\\NControle de trim, ligado.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 10,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Generator system, R.G.A.\\NActivating all control systems.",
    "traduzido" : "{\\i1}Sistema gerador, R.G.A. Ativando\\Ntodos os sistemas de controle.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 11,
    "estilo" : "Dialogue",
    "original" : "{\\i1}How's the pressure in\\Nthe plasma cylinder look?",
    "traduzido" : "{\\i1}Como está a pressão\\Nno cilindro de plasma?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 12,
    "estilo" : "Dialogue",
    "original" : "{\\i1}About 3 percent below normal.",
    "traduzido" : "{\\i1}Aproximadamente 3% abaixo do normal.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 13,
    "estilo" : "Dialogue",
    "original" : "{\\i1}It's barely within the pressure limit,",
    "traduzido" : "{\\i1}Está bem dentro do limite de pressão.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 14,
    "estilo" : "Dialogue",
    "original" : "{\\i1}but I'll make it work somehow.",
    "traduzido" : "{\\i1}Vou dar um jeito de fazer funcionar.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 15,
    "estilo" : "Dialogue",
    "original" : "{\\i1}We're going to release\\Nthe cables now. All set?{\\i}",
    "traduzido" : "{\\i1}Vamos soltar os cabos\\Nagora. Tudo pronto?{\\i}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 16,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Ready when you are.",
    "traduzido" : "{\\i1}Estou pronto quando voce estiver.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 17,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Cable release in five seconds,",
    "traduzido" : "{\\i1}Solte o cabo em cinco segundos",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 18,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Four...",
    "traduzido" : "{\\i1}Quatro...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 19,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Three...",
    "traduzido" : "{\\i1}Três...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 20,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Two...",
    "traduzido" : "{\\i1}Dois...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 21,
    "estilo" : "Dialogue",
    "original" : "{\\i1}One...",
    "traduzido" : "{\\i1}Um...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 22,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Take off!",
    "traduzido" : "{\\i1}Decolar!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 23,
    "estilo" : "Dialogue",
    "original" : "{\\i1}9000!",
    "traduzido" : "{\\i1}\"9000!\"",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 24,
    "estilo" : "Dialogue",
    "original" : "{\\i1}8500!",
    "traduzido" : "{\\i1}\"8500!\"",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 25,
    "estilo" : "Dialogue",
    "original" : "{\\i1}8000!",
    "traduzido" : "Shiro: {\\i1}8000!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 26,
    "estilo" : "Dialogue",
    "original" : "{\\i1}7500!",
    "traduzido" : "{\\i1}7500!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 27,
    "estilo" : "Dialogue",
    "original" : "{\\i1}7000!",
    "traduzido" : "{\\i1}7000!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 28,
    "estilo" : "Dialogue",
    "original" : "{\\i1}6500!",
    "traduzido" : "{\\i1}\"6500!\"",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 29,
    "estilo" : "Dialogue",
    "original" : "{\\i1}6000!",
    "traduzido" : "Shiro: {\\i1}6000!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 30,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Minovsky particle compressor\\Nfunctioning normally!",
    "traduzido" : "{\\i1}Compressor de particulas\\NMinovsky funcionando normalmente!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 31,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Plasma propulsion power is at point zero.{\\i}",
    "traduzido" : "{\\i1}Potência do propulsor a plasma está zerada.{\\i}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 32,
    "estilo" : "Dialogue",
    "original" : "{\\i1}Within predicted values.",
    "traduzido" : "{\\i1}Dentro dos valores previstos.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 33,
    "estilo" : "Dialogue",
    "original" : "{\\i1}No instability detected in gyro system.",
    "traduzido" : "{\\i1}Sem instabilidade detectada no sistema giroscópico.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 34,
    "estilo" : "Dialogue",
    "original" : "The vibration's less than I was expecting.",
    "traduzido" : "A vibracao e menor do que eu esperava.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 35,
    "estilo" : "Dialogue",
    "original" : "I'm increasing power.",
    "traduzido" : "Estou aumentando o poder.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 36,
    "estilo" : "Dialogue",
    "original" : "So, this... This is Big Brother's dream.",
    "traduzido" : "Então isso... Isso é o sonho do Grande Irmão.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 37,
    "estilo" : "Dialogue",
    "original" : "Hey, check it out!\\NThe Reaper's hard at work!",
    "traduzido" : "Olha só! A Parca\\Nestá em ação!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 38,
    "estilo" : "Dialogue",
    "original" : "Oh...? I feel sorry for poor Karen.",
    "traduzido" : "Sinto muito por Karen.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 39,
    "estilo" : "Dialogue",
    "original" : "Gettin' stuck with a jinx like him!",
    "traduzido" : "Ficar preso com um azarado como ele!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 40,
    "estilo" : "Dialogue",
    "original" : "No kidding! I pity them.",
    "traduzido" : "Sem brincadeira! Sinto pena deles.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 41,
    "estilo" : "Dialogue",
    "original" : "What are those guys talking about?",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 42,
    "estilo" : "Dialogue",
    "original" : "Does it not bother him to think of\\Nall his other teammates he's killed?",
    "traduzido" : "Não deve incomodar ele pensar\\Nnos outros colegas que matou?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 43,
    "estilo" : "Dialogue",
    "original" : "That newbie commander of his\\Nis probably dead meat, too.",
    "traduzido" : "Esse comandante novato dele\\Nprovavelmente também é carne morta.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 44,
    "estilo" : "Dialogue",
    "original" : "S-Sir...!",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 45,
    "estilo" : "Dialogue",
    "original" : "Betcha he'll haunt him forever after he dies—",
    "traduzido" : "Ele vai assombrá-lo para sempre depois que morrer.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 46,
    "estilo" : "Dialogue",
    "original" : "Sir, please!",
    "traduzido" : "Senhor, por favor!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 47,
    "estilo" : "Dialogue",
    "original" : "You son of a hitch!",
    "traduzido" : "Filho da mãe!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 48,
    "estilo" : "Dialogue",
    "original" : "Now you've done it, Reaper!",
    "traduzido" : "Agora você fez isso mesmo, Ceifador!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 49,
    "estilo" : "Dialogue",
    "original" : "Trouble!",
    "traduzido" : "Problema!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  } ]
}