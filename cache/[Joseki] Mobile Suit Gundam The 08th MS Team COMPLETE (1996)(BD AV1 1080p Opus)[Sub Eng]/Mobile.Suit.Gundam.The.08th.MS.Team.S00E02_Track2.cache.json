    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "022285fdf88ad44d099bc3d9f56de289a3d84c40cdf44b07b1a12f4c73feaa4d"
  }, {
    "indice" : 55,
    "estilo" : "Default",
    "original" : "I believe you!!!",
    "traduzido" : "Eu acredito em você!!!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "012fb5aa2bb1091c869fb815711844312dfd24ce905c3e35c25f426ff954a8a9"
  }, {
    "indice" : 56,
    "estilo" : "Default",
    "original" : "What?!",
    "traduzido" : "O que?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "004a6eba392afd9863052344bd804bfe9d488b84b2a746e03df6e8946510fc9b"
  }, {
    "indice" : 57,
    "estilo" : "Default",
    "original" : "Commander!",
    "traduzido" : "Comandante!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "7ad25fdd621cba9ed4a3b1c4831727a987e3525c08a375cd82d0f1074c6065c3"
  }, {
    "indice" : 58,
    "estilo" : "Default",
    "original" : "Which one was it? Which one exploded?",
    "traduzido" : "Qual foi? Qual explodiu?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "fbce8fd65fe0f3deeade2d7895e66538af9f6287f79591c2fa08332244a19b0a"
  }, {
    "indice" : 59,
    "estilo" : "Default",
    "original" : "I see, I see!",
    "traduzido" : "Eu vejo, eu vejo!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "47fbbdf7943a9a2fbb9e2e4ac63e0c29ce2ea7ed287bf63768947c8008a5af91"
  }, {
    "indice" : 60,
    "estilo" : "Default",
    "original" : "{\\i1}That's the commander for ya!",
    "traduzido" : "{\\i1}Esse é o comandante pra você!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "b6c3e1ac44275718553e2bc6f91dc0f2c19fda1106862cacf84a1063d4d8b2a2"
  }, {
    "indice" : 61,
    "estilo" : "Default",
    "original" : "{\\i1}Well, back to this problem.",
    "traduzido" : "{\\i1}Bom, voltando a esse problema.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "3f2790dd3c0f43a5bc333d4f6a38eccdd5f92d7dfc532c0f3be876e235212156"
  }, {
    "indice" : 62,
    "estilo" : "Default",
    "original" : "{\\i1}This isn't a manga.",
    "traduzido" : "{\\i1}Isso não é um mangá.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "103d1be13c2614b4582805e1a8f569c8413ae465a3f10254096d5c99330b9e2f"
  }, {
    "indice" : 63,
    "estilo" : "Default",
    "original" : "{\\i1}It's not like our social situation\\Nwill instantly change.",
    "traduzido" : "{\\i1}Não é como se nossa situação\\Nsocial mudasse instantaneamente.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "5456c9219c2d98c2f02f6343b9993d7ab135a376d043fd3741a64266e5894d99"
  }, {
    "indice" : 64,
    "estilo" : "Default",
    "original" : "How about it?",
    "traduzido" : "Como assim?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "5957a01c22540a02bd648efb3df225c67ab52bffee3b10e4d54f41d93767cd7b"
  }, {
    "indice" : 65,
    "estilo" : "Default",
    "original" : "O-Oh, u-uh... no thanks, I'm a minor...",
    "traduzido" : "O-Oh, u-uh... não obrigado, eu sou menor...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "4a32b7e908001a8f39e8be014c6df23f43db50d2047a92f93de6d0f4b3cc15aa"
  }, {
    "indice" : 66,
    "estilo" : "Default",
    "original" : "S-Sorry...",
    "traduzido" : "Sinto muito...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "7a3a22021aace19e3a1e2c8755c4cc9bfd65732feb190a459671c0c3f921b4f2"
  }, {
    "indice" : 67,
    "estilo" : "Default",
    "original" : "Wait a minute, just now, you...",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "850360a1f1130e9603296f4eba473e959293b2f99761d8018fc7b69d87618176"
  }, {
    "indice" : 68,
    "estilo" : "Default",
    "original" : "Chief!",
    "traduzido" : "Chief!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "067fa4f54a1a6bb0c73c3ec57514ee894c432948033cdd7c8209ef2e59bc03f8"
  }, {
    "indice" : 69,
    "estilo" : "Default",
    "original" : "Um, Chief!",
    "traduzido" : "Um momento, agora mesmo, você...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "87fc1dc66fbefb250d669647b195913997f8b16c22182d2f3048fdea37331273"
  }, {
    "indice" : 70,
    "estilo" : "Default",
    "original" : "You went through the trouble of offering\\Nme something, and I turned you down-",
    "traduzido" : "Voce ofereceu algo\\Npara mim e eu recusei.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "2b61ca5ebd8d1de1e4a3dc433301034624904cedb5c52fb0cbd152eae75bd04b"
  }, {
    "indice" : 71,
    "estilo" : "Default",
    "original" : "O-Oh, i-it's no-",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "28d75d44036ce78d407c50f542532113bfcc2364e110c40e28474fc74e178749"
  }, {
    "indice" : 72,
    "estilo" : "Default",
    "original" : "I'm sorry!",
    "traduzido" : "Eu sinto muito!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "4be43b98ba48488bd1418bedb26bbc1654e25a9134a4ca11b38b39cefcc1f389"
  }, {
    "indice" : 73,
    "estilo" : "Default",
    "original" : "However, if you wanted to drink coffee\\Ntogether, I'd be happy to! Here!",
    "traduzido" : "Entretanto, se voce quisesse tomar cafe\\Njuntos, eu ficaria feliz em fazer isso! Aqui!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
    "assinaturaContexto" : "b17b8d2868c3907ff8d43960b2ee22d16b8e3bba31e9fc0ae6d900ac7c55afee"
  }, {
    "indice" : 95,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}All that time that's passed me by.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Todo esse tempo que passou por mim.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 96,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}From childhood till now, so many days.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Desde a infância até hoje, tantos dias.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 97,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}When I look back, I see so many things...",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Quando olho para trás, vejo tantas coisas...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 98,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}...that happened to come into my life.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}...que acabou acontecendo na minha vida.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 99,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}The times I cried, the times I laughed.",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 100,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}The times I fought, the times I dreamed.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}As vezes que lutei, as vezes que sonhei.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 101,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}The lost loves that were sort of hard.",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 102,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}All shining in my history.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Brilhando em minha historia.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 103,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}The ones who caused me pain...",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Aqueles que me causaram dor...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 104,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}...I met and left along the way.",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 105,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}But I still ended up meeting you.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Mas ainda acabei me encontrando com você.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 106,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}The one that I love.",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 107,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}Ten years after, A decade from now.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0} Dez anos depois, uma década adiante.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 108,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}I wonder what I will be doing then.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Me pergunto o que estarei fazendo então.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 109,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}I wonder how I will be still loving you.",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 110,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}Ten years after, a decade from now.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0} Dez anos depois, uma década à frente.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 111,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}I still want to be looking at you.",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 112,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}Stay together. When that day comes...",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Fiquem juntos. Quando aquele dia chegar...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 113,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}...I want to be at your side with a smile.",
    "traduzido" : "",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  } ]
}