  },
  "entradas" : [ {
    "indice" : 1,
    "estilo" : "Titles",
    "original" : "{\\blur1\\pos(952,608)\\c&HFEFEFE&}The Battle in Three Dimensions",
    "traduzido" : "{\\blur1\\pos(952,608)\\c&HFEFEFE&}A Batalha em Três Dimensões",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 2,
    "estilo" : "Default",
    "original" : "{\\i1}Hey B.B., was there someone\\Nlike this in your class...?",
    "traduzido" : "{\\i1}Ei, B.B., tinha alguém\\Nassim na sua turma...?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 3,
    "estilo" : "Default",
    "original" : "{\\i1}I mean, someone who was hard to talk to?",
    "traduzido" : "{\\i1}Eu quis dizer, alguém difícil de se conversar?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 4,
    "estilo" : "Default",
    "original" : "{\\i1}It's not that he was unpleasant,\\Nor that you hate him or anything.",
    "traduzido" : "{\\i1}Ele não era desagradável\\Nnem você o odeia ou algo assim.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 5,
    "estilo" : "Default",
    "original" : "{\\i1}I guess it's hard to judge how\\Nclose you can get to them...",
    "traduzido" : "{\\i1}Acho difícil julgar o quanto\\Nperto se pode chegar deles...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 6,
    "estilo" : "Default",
    "original" : "{\\i1}The kind of person you graduate with...",
    "traduzido" : "{\\i1}O tipo de pessoa que você se forma com...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 7,
    "estilo" : "Default",
    "original" : "{\\i1}...without ever having talked\\Nto them even once.",
    "traduzido" : "{\\i1}Sem nunca ter falado\\Ncom eles, nem mesmo uma vez.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 8,
    "estilo" : "Default",
    "original" : "{\\i1}If only Eledore were here\\Nat times like these!",
    "traduzido" : "{\\i1}Ah, se Eledore estivesse\\Naqui nestes momentos!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 9,
    "estilo" : "Default",
    "original" : "{\\i1}His complete and utter lack of social skills would come in really handy right about now!",
    "traduzido" : "{\\i1}Seu completo e absoluto desinteresse pelas habilidades sociais seria bem útil agora mesmo!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 10,
    "estilo" : "Default",
    "original" : "{\\i1}A bridge, huh?",
    "traduzido" : "{\\i1}Uma ponte, é?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 11,
    "estilo" : "Default",
    "original" : "{\\i1}So that means we've finally\\Nreached the halfway mark.",
    "traduzido" : "{\\i1}Finalmente chegamos\\Nà marca do meio.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 12,
    "estilo" : "Default",
    "original" : "A sniper!",
    "traduzido" : "Um atirador de elite!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 13,
    "estilo" : "Default",
    "original" : "Karen!",
    "traduzido" : "Karen!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 14,
    "estilo" : "Default",
    "original" : "More of them?!",
    "traduzido" : "Mais deles?!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 15,
    "estilo" : "Default",
    "original" : "A Flight Type?!",
    "traduzido" : "Um Flight Type?!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 16,
    "estilo" : "Default",
    "original" : "Such tough armor!",
    "traduzido" : "Que armadura resistente!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 17,
    "estilo" : "Default",
    "original" : "And the other one still wasn't\\Ndestroyed, even after that!",
    "traduzido" : "E o outro ainda não foi\\Ndestruído, mesmo depois disso!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 18,
    "estilo" : "Default",
    "original" : "Karen!",
    "traduzido" : "Karen!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 19,
    "estilo" : "Default",
    "original" : "{\\i1}Can you read me? Karen!{\\i0}",
    "traduzido" : "{\\i1}Karen, você me escuta?{\\i0}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 20,
    "estilo" : "Default",
    "original" : "Wasn't this area supposed\\Nto be under our control?!",
    "traduzido" : "Não era suposto esta área\\Nestar sob nosso controle?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 21,
    "estilo" : "Default",
    "original" : "Hurry! Prepare the next round!",
    "traduzido" : "Preparem a próxima rodada!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 22,
    "estilo" : "Default",
    "original" : "{\\i1}Move your aim more to the left!{\\i0}",
    "traduzido" : "{\\i1}Meu alvo está mais para a esquerda!{\\i0}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 23,
    "estilo" : "Default",
    "original" : "{\\i1}Keep them pinned down for 15 minutes!{\\i0}",
    "traduzido" : "{\\i1}Mantenha-os imobilizados por 15 minutos!{\\i0}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 24,
    "estilo" : "Default",
    "original" : "Fire!",
    "traduzido" : "Fogo!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 25,
    "estilo" : "Default",
    "original" : "Commander!",
    "traduzido" : "Comandante!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 26,
    "estilo" : "Default",
    "original" : "{\\i1}Michel! Grab Karen and get her out of there!{\\i0}",
    "traduzido" : "{\\i1}Michel! Pega a Karen e tira ela dali!{\\i0}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 27,
    "estilo" : "Default",
    "original" : "Huh?!",
    "traduzido" : "Huh?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 28,
    "estilo" : "Default",
    "original" : "We're at a disadvantage here on\\Nthe bridge. We need to pull back!",
    "traduzido" : "Estamos em desvantagem aqui\\Nna ponte. Precisamos recuar!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 29,
    "estilo" : "Default",
    "original" : "It's too far out!",
    "traduzido" : "É muito longe!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 30,
    "estilo" : "Default",
    "original" : "How did we get into this mess?!",
    "traduzido" : "Como nós nos metemos nessa bagunça?!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 31,
    "estilo" : "Default",
    "original" : "Michel! Sanders!",
    "traduzido" : "Michel! Sanders!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 32,
    "estilo" : "Default",
    "original" : "Do you really think I'd give you\\Ntime to help your comrades?!",
    "traduzido" : "Eu realmente acho que daria tempo\\Npara você ajudar seus companheiros?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 33,
    "estilo" : "Default",
    "original" : "This is insane! Two against one?!",
    "traduzido" : "Isso é loucura! Dois contra um?!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 34,
    "estilo" : "Default",
    "original" : "I don't...",
    "traduzido" : "Eu não...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 35,
    "estilo" : "Default",
    "original" : "...think so!",
    "traduzido" : "Penso que sim!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 36,
    "estilo" : "Default",
    "original" : "Sorry Karen, I'm borrowing this!",
    "traduzido" : "Desculpe, Karen, estou pegando emprestado!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 37,
    "estilo" : "Default",
    "original" : "Okay! It's stopped!",
    "traduzido" : "Okay! Parou!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 38,
    "estilo" : "Default",
    "original" : "Fire!",
    "traduzido" : "Fogo!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 39,
    "estilo" : "Default",
    "original" : "He made that shot... from that distance?!",
    "traduzido" : "Ele fez aquele tiro... àquela distância?!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 40,
    "estilo" : "Default",
    "original" : "So he's an ace pilot, huh?",
    "traduzido" : "Ele é um piloto ACE, é?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 41,
    "estilo" : "Default",
    "original" : "All right then!",
    "traduzido" : "Então está bem!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 42,
    "estilo" : "Default",
    "original" : "The enemy is making me fight\\Nthree-dimensionally!",
    "traduzido" : "O inimigo está me forçando\\Na lutar em três dimensões!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 43,
    "estilo" : "Default",
    "original" : "Here.",
    "traduzido" : "Aqui.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 44,
    "estilo" : "Default",
    "original" : "But we're up against a mobile suit!",
    "traduzido" : "Mas estamos enfrentando um Mobile Suit!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 45,
    "estilo" : "Default",
    "original" : "Do we really have any other options here?",
    "traduzido" : "Não temos muitas outras opções aqui, não é mesmo?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 46,
    "estilo" : "Default",
    "original" : "Well, I...",
    "traduzido" : "Bem, eu...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 47,
    "estilo" : "Default",
    "original" : "Chief, help me with something!",
    "traduzido" : "Chefe, preciso da sua ajuda com uma coisa!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 48,
    "estilo" : "Default",
    "original" : "With what?",
    "traduzido" : "Com o que?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 49,
    "estilo" : "Default",
    "original" : "I have an idea!",
    "traduzido" : "Tenho uma ideia!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 50,
    "estilo" : "Default",
    "original" : "Michel! You okay?!",
    "traduzido" : "Michel! Tudo bem?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 51,
    "estilo" : "Default",
    "original" : "S-Somehow, yes!",
    "traduzido" : "Sim, de alguma forma!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 52,
    "estilo" : "Default",
    "original" : "{\\i1}C-Commander, he's headed your way!\\NHe's 30 meters behind you!{\\i0}",
    "traduzido" : "{\\i1}Comandante, ele está vindo em sua direção!\\NEle está a 30 metros atrás de você!{\\i0}",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 53,
    "estilo" : "Default",
    "original" : "How do you know that?!",
    "traduzido" : "Como você sabe disso?!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 54,
    "estilo" : "Default",
    "original" : "He's coming! In 3! 2! 1!",
    "traduzido" : "Ele está chegando! Em 3! 2! 1!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 55,
    "estilo" : "Default",
    "original" : "I believe you!!!",
    "traduzido" : "Eu acredito em você!!!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 56,
    "estilo" : "Default",
    "original" : "What?!",
    "traduzido" : "O quê?!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 57,
    "estilo" : "Default",
    "original" : "Commander!",
    "traduzido" : "Comandante!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 58,
    "estilo" : "Default",
    "original" : "Which one was it? Which one exploded?",
    "traduzido" : "Qual foi? Qual explodiu?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 59,
    "estilo" : "Default",
    "original" : "I see, I see!",
    "traduzido" : "Eu vejo, eu vejo!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 60,
    "estilo" : "Default",
    "original" : "{\\i1}That's the commander for ya!",
    "traduzido" : "{\\i1}Esse é o comandante para você!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 61,
    "estilo" : "Default",
    "original" : "{\\i1}Well, back to this problem.",
    "traduzido" : "{\\i1}Bem, voltando a esse problema.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 62,
    "estilo" : "Default",
    "original" : "{\\i1}This isn't a manga.",
    "traduzido" : "{\\i1}Isso não é um mangá.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 63,
    "estilo" : "Default",
    "original" : "{\\i1}It's not like our social situation\\Nwill instantly change.",
    "traduzido" : "{\\i1}Não é como se nossa situação\\Nsocial mudasse instantaneamente.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 64,
    "estilo" : "Default",
    "original" : "How about it?",
    "traduzido" : "Como é que está?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 65,
    "estilo" : "Default",
    "original" : "O-Oh, u-uh... no thanks, I'm a minor...",
    "traduzido" : "Eu não quero, obrigado, eu sou menor de idade",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 66,
    "estilo" : "Default",
    "original" : "S-Sorry...",
    "traduzido" : "Desculpa...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 67,
    "estilo" : "Default",
    "original" : "Wait a minute, just now, you...",
    "traduzido" : "Espere um pouco, agora mesmo você...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 68,
    "estilo" : "Default",
    "original" : "Chief!",
    "traduzido" : "Chefe!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 69,
    "estilo" : "Default",
    "original" : "Um, Chief!",
    "traduzido" : "Um, Chefe!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 70,
    "estilo" : "Default",
    "original" : "You went through the trouble of offering\\Nme something, and I turned you down-",
    "traduzido" : "Você se deu ao trabalho de me\\Noferecer algo, e eu recusei.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 71,
    "estilo" : "Default",
    "original" : "O-Oh, i-it's no-",
    "traduzido" : "Oh, é...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 72,
    "estilo" : "Default",
    "original" : "I'm sorry!",
    "traduzido" : "Desculpa!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 73,
    "estilo" : "Default",
    "original" : "However, if you wanted to drink coffee\\Ntogether, I'd be happy to! Here!",
    "traduzido" : "Mas se você quiser tomar café juntos,\\Nficarei feliz em fazer isso! Aqui!",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 95,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}All that time that's passed me by.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Tudo esse tempo que passou por mim.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 96,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}From childhood till now, so many days.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}De infância até agora, tantos dias.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 97,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}When I look back, I see so many things...",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Quando olho para trás, vejo tantas coisas...",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 98,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}...that happened to come into my life.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}...que aconteceu de entrar na minha vida.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 99,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}The times I cried, the times I laughed.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Os tempos que chorei, os tempos que ri.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 100,
    "estilo" : "Song ENG",
    "original" : "{\\fad(150,150)\\blur0.5\\bord0}The times I fought, the times I dreamed.",
    "traduzido" : "{\\fad(150,150)\\blur0.5\\bord0}Os tempos que lutei, os tempos que sonhei.",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br"
  }, {
    "indice" : 101,
