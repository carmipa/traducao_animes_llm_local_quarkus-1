  }, {
    "indice" : 2,
    "estilo" : "Default",
    "original" : "{\\i1}Hey B.B., was there someone\\Nlike this in your class...?",
    "traduzido" : "{\\i1}Ei B.B., tinha alguém\\Nassim na sua turma...?",
    "idiomaOriginal" : "en",
    "idiomaTraduzido" : "pt-br",
