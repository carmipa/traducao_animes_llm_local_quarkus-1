# --- Artefatos gerados de build (nunca versionar) ---
.gradle/
build/
bin/

# --- Ferramentas e configuração local ---
.codex/
.mcp.json

# --- Configuração local da aplicação (contém chaves/credenciais) ---
# Ignora o arquivo real, mas preserva o template .example versionável.
application-local.yml
**/application-local.yml
!application-local.yml.example
!**/application-local.yml.example

# --- Arquivos temporários ---
*.tmp
*.bak
*~
.DS_Store
Thumbs.db

# --- Artefatos de runtime (nunca versionar) ---
# Cache de tradução, logs/telemetria de execução e backups são gerados em
# tempo de execução. Ignora-se por PASTA, não por extensão: um filtro global
# como "*.cache.json" quebraria fixtures de teste versionados
# (ex.: src/test/resources/cachetraducao/legado.cache.json).
cache/
logs/
backups/
